# FAC Audit Alert — configuration
# Copy this file to .env and fill in your values

# API key from https://api.data.gov/signup/
FAC_API_KEY=your_data_gov_api_key_here

# Two-letter state code to monitor (e.g. CA, TX, NY)
WATCH_STATE=CA

# Gmail address used to SEND the alert
EMAIL_FROM=you@gmail.com

# Gmail App Password (NOT your regular password)
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Recipient email address(es) — comma-separated for multiple
EMAIL_TO=recipient@example.com

# Optional overrides
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# STATE_FILE=last_check.json
